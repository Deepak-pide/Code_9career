
{
  "entities": {
    "Specialization": {
      "title": "Specialization",
      "description": "A category of expertise for teams (e.g., Web Dev, UI/UX).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string", "description": "Lucide icon name" },
        "imageUrl": { "type": "string", "description": "Optional URL for a custom icon or logo" },
        "color": { "type": "string", "enum": ["blue", "pink", "purple", "amber", "rose", "cyan", "indigo"] }
      },
      "required": ["id", "label", "description", "color"]
    },
    "Team": {
      "title": "Core Team",
      "description": "A specific project squad looking for members.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "company": { "type": "string" },
        "description": { "type": "string" },
        "categoryId": { "type": "string" },
        "seats": { "type": "string", "description": "e.g. '1/3'" },
        "stipend": { "type": "string" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "theme": { "type": "string", "enum": ["blue", "pink", "purple", "green", "amber", "cyan", "rose"] }
      },
      "required": ["name", "company", "description", "categoryId", "seats", "stipend", "skills", "theme"]
    },
    "TeamRequest": {
      "title": "Team Request",
      "description": "A request from a student to join a specific team.",
      "type": "object",
      "properties": {
        "teamName": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"] },
        "timestamp": { "type": "number" }
      },
      "required": ["teamName", "userName", "userEmail", "status", "timestamp"]
    },
    "Enquiry": {
      "title": "Enquiry",
      "description": "A business enquiry from the services page.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "service": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["name", "email", "service", "message", "timestamp"]
    }
  },
  "auth": {
    "providers": ["email"]
  },
  "firestore": {
    "/specializations/{specializationId}": {
      "schema": "Specialization",
      "description": "Available team categories."
    },
    "/teams/{teamId}": {
      "schema": "Team",
      "description": "Active project squads."
    },
    "/requests/{requestId}": {
      "schema": "TeamRequest",
      "description": "Student applications for teams."
    },
    "/enquiries/{enquiryId}": {
      "schema": "Enquiry",
      "description": "Service enquiries from potential clients."
    }
  }
}
